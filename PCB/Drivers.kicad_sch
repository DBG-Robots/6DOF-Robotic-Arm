	(text "Note CAN Bus Termination (JP1):\n120Ω termination resistor (R12) between CAN_H and CAN_L.\nJP1 (solder bridge) controls whether the resistor is active.\nClose JP1 if this board is located at the end of the CAN bus.\nLeave JP1 open if board is mid-bus or if bus is already terminated.\nDefault: OPEN (unterminated)\nExactly two 120Ω terminations must be present across entire CAN bus."
		(exclude_from_sim no)
		(at 106.426 182.118 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "5828a3ab-22bb-49e7-8d95-971a74293040")
	)
	(text "SPREAD pin:\n- Pull LOW (Gnd): StealthChop2 (ultra quiet)\n- Pull HIGH (3V3): SpreadCycle (Max Torque)\n\nOnly ever have exactly ONE bridge between two solder\npads to prevent undefined behaviour or a short!"
		(exclude_from_sim no)
		(at 177.292 173.228 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "f3f54d96-3258-49aa-8b89-43ff71ad0d3b")
	)
